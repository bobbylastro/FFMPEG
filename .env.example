# Twitch API
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# YouTube API
YOUTUBE_CLIENT_ID=your_yt_client_id_here
YOUTUBE_CLIENT_SECRET=your_yt_client_secret_here

# TikTok API
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# Config
GAME=Valorant
CLIPS_DAYS_AGO_START=14
CLIPS_DAYS_AGO_END=2
CLIPS_PER_VIDEO=12
MAX_CLIP_DURATION=45
EXCLUDED_LANGUAGES=ja,ko,zh

# Cloudflare R2 — Ultimate Playground
R2_ACCESS_KEY=your_r2_access_key_here
R2_SECRET_KEY=your_r2_secret_key_here

# Supabase — Ultimate Playground
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
